<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="MyKeyboardView">
        <attr name="keyBackgroundColor" format="color" />
        <attr name="keyPressedBackgroundColor" format="color" />
        <attr name="keyTextColor" format="color" />
        <attr name="functionalKeyTextColor" format="color" />
    </declare-styleable>

    <declare-styleable name="MyKey">
        <attr name="shiftedCode" format="integer" />
        <attr name="forPackage" format="string" />
    </declare-styleable>

    <attr name="keyboardViewBackground" format="color|reference" />
    <attr name="keyboardKeyBackground" format="color|reference" />
    <attr name="functionalKeyBackground" format="color|reference" />
    <attr name="keyboardKeyTextColor" format="color" />
    <attr name="keyPreviewBackground" format="color|reference" />
    <attr name="keyPreviewTextColor" format="color" />
    <attr name="candidatesBackground" format="color|reference" />
    <attr name="candidatesTextColor" format="color" />
    <attr name="iconColor" format="color" />
    <attr name="iconBackspace" format="reference" />

</resources>
