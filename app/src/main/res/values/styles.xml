<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/keyboard_background_light</item>
        <item name="colorPrimaryDark">@color/keyboard_background_dark</item>
        <item name="colorAccent">@color/key_text_light</item>
    </style>

    <style name="WeekHeader">
    </style>

    <style name="WeekDayText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
