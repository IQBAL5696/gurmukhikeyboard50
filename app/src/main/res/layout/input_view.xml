<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_input_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/keyboardViewBackground">

    <!-- Container for Keyboard + Bottom Navigation Spacer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- This horizontal container handles the split and one-handed logic -->
        <LinearLayout
            android:id="@+id/one_handed_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="100">

            <!-- Left Control Panel -->
            <LinearLayout
                android:id="@+id/one_handed_spacer_left"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="15"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/btn_move_to_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/outline_arrows_output_24"
                    app:tint="?attr/iconColor" />

                <ImageButton
                    android:id="@+id/btn_expand_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_keyboard"
                    app:tint="?attr/iconColor" />
            </LinearLayout>

            <!-- Main Keyboard Area -->
            <LinearLayout
                android:id="@+id/mainKeyboardLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="100"
                android:orientation="vertical"
                android:background="@android:color/transparent">

                <include
                    android:id="@+id/translation_panel_container"
                    layout="@layout/translation_panel_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/transparent">

                    <include
                        android:id="@+id/suggestion_panel_root"
                        layout="@layout/suggestion_panel_root"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#22000000" />

                    <include
                        android:id="@+id/fixed_top_row_buttons"
                        layout="@layout/fixed_top_row_buttons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33CCCCCC" />
                </LinearLayout>

                <include
                    android:id="@+id/expanded_top_row_container"
                    layout="@layout/expanded_top_row_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@android:color/transparent">

                    <com.iqbal.gurmukhikeyboard50.MyKeyboardView
                        android:id="@+id/keyboardView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:keyPreviewLayout="@layout/small_key_preview"
                        android:popupLayout="@layout/keyboard_popup_layout"
                        android:keyPreviewHeight="50dp" />
                </FrameLayout>
            </LinearLayout>

            <!-- Right Control Panel -->
            <LinearLayout
                android:id="@+id/one_handed_spacer_right"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="15"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/btn_move_to_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/outline_arrows_output_24"
                    android:rotation="180"
                    app:tint="?attr/iconColor" />

                <ImageButton
                    android:id="@+id/btn_expand_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_keyboard"
                    app:tint="?attr/iconColor" />
            </LinearLayout>

        </LinearLayout>

        <!-- Dynamic Spacer based on Orientation -->
        <View
            android:id="@+id/navigation_bar_spacer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_spacer_height"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- Overlays -->
    <include
        android:id="@+id/suggestion_panel"
        layout="@layout/suggestion_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/nanakshahi_calendar_panel_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <include
        android:id="@+id/emoji_panel_container"
        layout="@layout/emoji_panel_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <include
        android:id="@+id/voice_input_popup_container"
        layout="@layout/voice_input_popup_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="50dp"
        android:visibility="gone" />

    <include
        android:id="@+id/clipboard_panel_layout"
        layout="@layout/clipboard_panel_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="10dp"
        android:visibility="gone" />

</FrameLayout>
