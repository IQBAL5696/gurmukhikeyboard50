<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:background="?attr/keyboardViewBackground">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="2dp">

        <!-- ਬੰਦ ਕਰਨ ਲਈ -->
        <ImageButton
            android:id="@+id/close_expanded_row"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

        <View android:layout_width="1dp" android:layout_height="25dp" android:background="#33000000" android:layout_margin="4dp"/>

        <!-- Text Actions -->
        <ImageButton
            android:id="@+id/btn_select_all"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

        <ImageButton
            android:id="@+id/btn_copy"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_clipboard"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

        <ImageButton
            android:id="@+id/btn_paste"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_continue_writing"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

        <View android:layout_width="1dp" android:layout_height="25dp" android:background="#33000000" android:layout_margin="4dp"/>

        <!-- Font Size Controls -->
        <Button
            android:id="@+id/btn_font_decrease"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:text="A-"
            android:textSize="12sp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:textColor="?attr/iconColor" />

        <Button
            android:id="@+id/btn_font_increase"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:text="A+"
            android:textSize="16sp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:textColor="?attr/iconColor" />

        <View android:layout_width="1dp" android:layout_height="25dp" android:background="#33000000" android:layout_margin="4dp"/>

        <!-- ਗੁਰਬਾਣੀ ਸਰਚ ਸ਼ਾਰਟਕੱਟ -->
        <ImageButton
            android:id="@+id/btn_gurbani_search_shortcut"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_search"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

        <View android:layout_width="1dp" android:layout_height="25dp" android:background="#33000000" android:layout_margin="4dp"/>

        <!-- Cursor Control -->
        <ImageButton
            android:id="@+id/btn_cursor_left"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/outline_arrows_output_24"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:rotation="180"
            app:tint="?attr/iconColor" />

        <ImageButton
            android:id="@+id/btn_cursor_right"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:src="@drawable/outline_arrows_output_24"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="?attr/iconColor" />

    </LinearLayout>
</HorizontalScrollView>
