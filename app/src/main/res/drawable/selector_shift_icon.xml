<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when shift is ON (checked state for sticky key) -->
    <item android:state_checked="true"
          android:drawable="@drawable/ic_shift_on" />
    <!-- Default state (shift OFF) -->
    <item android:drawable="@drawable/ic_shift_off" />
</selector>